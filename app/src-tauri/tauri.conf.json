{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/refs/heads/dev/crates/tauri-config-schema/schema.json",
  "productName": "Spaghetti Lab",
  "version": "2026.4.1-preview.1",
  "identifier": "com.spaghettilab.analyzer",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "bundle": {
    "category": "Utility",
    "createUpdaterArtifacts": true,
    "fileAssociations": [
      {
        "ext": ["spag"],
        "mimeType": "application/x-spaghetti-lab",
        "description": "Spaghetti Lab Replay Analysis"
      },
      {
        "ext": ["spagz"],
        "mimeType": "application/x-spaghetti-lab-lite",
        "description": "Spaghetti Lab Analysis (no video)"
      }
    ],
    "resources": {
      "../../scripts/analyze_replay.py": "scripts/analyze_replay.py",
      "../../scripts/analyze_sets.py": "scripts/analyze_sets.py",
      "../../scripts/split_vod.py": "scripts/split_vod.py",
      "../../replanal/**/*": "replanal/",
      "../../config/default.yaml": "config/default.yaml"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/TimesUp94/spaghettilab/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE5N0Y1OEJCMDdDMzY3OTMKUldTVFo4TUh1MWgvR1hwRE1aYUJ3QkFiYlNlZ052eXNtaXpQdHBXa0phQ2R5WWNUYWNQZnd2aVQK"
    }
  },
  "app": {
    "windows": [
      {
        "title": "Spaghetti Lab - GGS Replay Analyzer",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "decorations": true,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["**"],
          "deny": []
        }
      }
    }
  }
}
