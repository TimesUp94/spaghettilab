{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/refs/heads/dev/crates/tauri-config-schema/schema.json",
  "productName": "Spaghetti Lab",
  "version": "2026.3.16-preview.2",
  "identifier": "com.spaghettilab.analyzer",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "bundle": {
    "fileAssociations": [
      {
        "ext": ["spag"],
        "mimeType": "application/x-spaghetti-lab",
        "description": "Spaghetti Lab Replay Analysis"
      }
    ],
    "resources": {
      "../../scripts/analyze_replay.py": "scripts/analyze_replay.py",
      "../../scripts/analyze_sets.py": "scripts/analyze_sets.py",
      "../../scripts/split_vod.py": "scripts/split_vod.py",
      "../../replanal/**/*": "replanal/",
      "../../config/default.yaml": "config/default.yaml"
    }
  },
  "app": {
    "windows": [
      {
        "title": "Spaghetti Lab - GGS Replay Analyzer",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "decorations": true,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["**"],
          "deny": []
        }
      }
    }
  }
}
